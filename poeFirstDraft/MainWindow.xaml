                <!-- shield icon row вҖ” small and clean -->
                <TextBlock
            FontFamily="Courier New"
            FontSize="8"
            Foreground="#4ECDC4"
            HorizontalAlignment="Center"
            TextAlignment="Center"
            LineHeight="16"
            Margin="0,0,0,4"
            xml:space="preserve">
  /####\   в–ә Firewall   : ON
 /  ##  \  в–ә Encryption : ON
/___##___\ в–ә Threats    : BLOCKED</TextBlock>

                <TextBlock
                    Text="[PROTECT  |  DETECT  |  SECURE ]"
                    FontFamily="Courier New"
                    FontSize="13"
                    Foreground="#4ECDC4"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,30"/>

                <!-- label to prompt the user -->
                <TextBlock
                Text="Enter your name:"
                Foreground="#A0A0A0"
                FontSize="13"
                Margin="0,0,0,8"
                HorizontalAlignment="Center"
                />

                <!-- textbox to capture username -->
                <TextBox
                x:Name="user_name"
                Height="42"
                FontSize="14"
                Background="#161B22"
                Foreground="White"
                CaretBrush="WhiteSmoke"
                BorderBrush="#00FF9C"
                BorderThickness="1.5"
                Padding="10,8"
                Margin="0,0,0,14"
                />

                <!-- button to submit username -->
                <Button
                Content="Submit Username"
                Height="44"
                FontSize="14"
                FontWeight="Bold"
                Background="#00FF9C"
                Foreground="#0D1117"
                BorderThickness="0"
                Cursor="Hand"
                Click="submit_name"
                />
            </StackPanel>

        </Grid>
        <!-- end of username grid -->


        <!-- Grid for the chats page -->
        <Grid
            x:Name="chats_grid"
            Visibility="Hidden"
            >
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- My Header-->
                <RowDefinition Height="*"/>
                <!-- chat list-->
                <RowDefinition Height="Auto"/>
                <!-- input area-->
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Background="#161B22"
                BorderBrush="#00FF9C"
                BorderThickness="0,0,0,1.5"
                Padding="16,10">
                <TextBlock 
                    Text=" CYBER SECURITY BOT - YOU MAY ASK ME ANYTHING "
                    Foreground="#00FF9C"
                    FontFamily="Courier New"
                    FontSize="13"
                    FontWeight="Bold"/>
            </Border>

            <!-- start of chats grid -->

            <!-- list view to show chats -->
            <Border 
                Grid.Row="1"
                Background="#0D1117"
                Margin="10,10,10,0">

                <ListView
                x:Name="chats"
                Background="Transparent"
                BorderThickness="0"
                Foreground="White"
                FontSize="13"
                FontFamily="Segoe UI"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                VirtualizingPanel.ScrollUnit="Pixel"
                />
            </Border>
            <Border 
                Grid.Row="2"
                Background="#161B22"
                BorderBrush="#30363D"
                Padding="10,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>


                    <!-- the question TextBox -->
                    <TextBox
                Grid.Column="0"
                x:Name="question"
                Height="42"
                FontSize="13"
                Background="#0D1117"
                Foreground="White"
                CaretBrush="White"
                BorderBrush="#30363D"
                BorderThickness="1"
                Padding="12,10"
                Margin="0,0,8,0"/>



                    <!-- button to submit the question -->
                    <Button
               Grid.Column="1"
                Content="SEND вҶ’"
                Height="42"
                Width="100"
                FontSize="13"
                FontWeight="Bold"
                Background="#00FF9C"
                Foreground="#0D1117"
                BorderThickness="0"
                Cursor="Hand"
                Click="Send"
                />
                </Grid>
            </Border>

        </Grid>
        <!-- end of chats grid -->


    </Grid>
    <!-- end of parent grid -->
</Window>

